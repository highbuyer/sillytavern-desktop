{
  "name": "sillytavern-desktop",
  "version": "10.0.0",
  "description": "Desktop application for SillyTavern",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "server": "vite --host",
    "build": "tsc && vite build && electron-builder build",
    "dist": "npm run build && electron-builder --publish=never",
    "preview": "vite preview",
    "start": "ELECTRON_DISABLE_SANDBOX=1 npm run server & sleep 5 && ELECTRON_DISABLE_SANDBOX=1 npx electron ."
  },
  "keywords": [
    "sillytavern",
    "desktop",
    "chat",
    "ai"
  ],
  "author": "SillyTavern Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.3.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.1",
    "zustand": "^4.3.6"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@types/node": "^18.14.0",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@vitejs/plugin-react": "^3.1.0",
    "electron": "^28.2.3",
    "electron-builder": "^24.6.3",
    "esbuild": "^0.28.0",
    "typescript": "^4.9.5",
    "vite": "^4.5.2"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
